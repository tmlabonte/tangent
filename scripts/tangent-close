#!/bin/bash
set -euo pipefail
# tangent-close -- clean up a tangent pane, branch, and worktree.
#
# Run from inside the tangent pane, or pass a branch name:
#   tangent-close              # closes current pane's tangent
#   tangent-close <branch>     # closes by branch name (from any pane)

WORKTREE_ROOT="${WORKTREE_ROOT:-/data/worktrees}"

die() { echo "tangent-close: $*" >&2; exit 1; }

CALLER_PANE="${TMUX_PANE:-}"

if [[ -n "${1:-}" ]]; then
    BRANCH="$1"
    WORKTREE_DIR="${WORKTREE_ROOT}/${BRANCH}"

    # Find the pane whose cwd is inside the worktree
    PANE_ID=""
    while IFS=' ' read -r pid ppath; do
        if [[ "$ppath" == "$WORKTREE_DIR"* && "$pid" != "$CALLER_PANE" ]]; then
            PANE_ID="$pid"
            break
        fi
    done <<< "$(tmux list-panes -a -F '#{pane_id} #{pane_current_path}')"

    # Kill the tangent pane
    if [[ -n "$PANE_ID" ]]; then
        tmux kill-pane -t "$PANE_ID" 2>/dev/null || true
        echo "tangent-close: killed pane $PANE_ID ($BRANCH)"
    else
        echo "tangent-close: no pane found for branch $BRANCH"
    fi

    # Remove the git worktree. Refuse to follow a symlink — removing the
    # symlink target would wipe another (real) worktree.
    if [[ -L "$WORKTREE_DIR" ]]; then
        echo "tangent-close: $WORKTREE_DIR is a symlink — removing only the link, not the target"
        rm "$WORKTREE_DIR"
    elif [[ -d "$WORKTREE_DIR" ]]; then
        git worktree remove --force "$WORKTREE_DIR" 2>/dev/null ||
        rm -rf "$WORKTREE_DIR" 2>/dev/null || true
        echo "tangent-close: removed worktree $WORKTREE_DIR"
    fi
    git worktree prune 2>/dev/null || true

else
    # We're in the tangent pane — detect from pane title (set by tangent) or cwd
    BRANCH=$(tmux display-message -p '#{pane_title}' 2>/dev/null || true)
    BRANCH="${BRANCH#🌿 }"  # strip tangent prefix if present
    if [[ -n "$BRANCH" && -d "${WORKTREE_ROOT}/${BRANCH}" ]]; then
        WORKTREE_DIR="${WORKTREE_ROOT}/${BRANCH}"
    else
        WORKTREE_DIR=$(pwd)
        if [[ "$WORKTREE_DIR" != "$WORKTREE_ROOT"/* ]]; then
            die "not in a worktree under $WORKTREE_ROOT (and no pane title set)"
        fi
        BRANCH="${WORKTREE_DIR#$WORKTREE_ROOT/}"
        BRANCH="${BRANCH%%/*}"
        WORKTREE_DIR="${WORKTREE_ROOT}/${BRANCH}"
    fi

    # Remove the git worktree before killing our own pane
    if [[ -d "$WORKTREE_DIR" ]]; then
        cd /tmp  # leave the worktree so it can be removed
        git worktree remove --force "$WORKTREE_DIR" 2>/dev/null ||
        rm -rf "$WORKTREE_DIR" 2>/dev/null || true
    fi
    git worktree prune 2>/dev/null || true

    # Kill our own pane (this is the last thing we do)
    tmux kill-pane
fi
