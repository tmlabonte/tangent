#!/usr/bin/env python3
"""pr-daemon — polls GitHub for PR activity and routes to Claude panes via tmux."""

import fcntl
import json
import logging
import os
import signal
import subprocess
import sys
import time
import yaml
from datetime import datetime, timezone, timedelta
from zoneinfo import ZoneInfo
from pathlib import Path

STATE_DIR = Path.home() / ".local/state/pr-daemon"
CONFIG_PATH = Path.home() / ".config/pr-daemon/config.yaml"
LOCK_FILE = STATE_DIR / "daemon.lock"
EVENT_LOG = STATE_DIR / "events.jsonl"
CURSOR_FILE = STATE_DIR / "cursors.json"
INBOX_FILE = STATE_DIR / "inbox.txt"
LOG_FILE = STATE_DIR / "daemon.log"
TANGENT = Path.home() / ".local/bin/tangent"

STATE_DIR.mkdir(parents=True, exist_ok=True)

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s %(message)s",
    handlers=[logging.StreamHandler(sys.stderr)],
)
log = logging.getLogger("pr-daemon")


def _log_to_file():
    """Redirect Python logger to LOG_FILE (append mode). Called after fork."""
    root = logging.getLogger()
    for h in list(root.handlers):
        root.removeHandler(h)
    fh = logging.FileHandler(LOG_FILE)
    fh.setFormatter(logging.Formatter("%(asctime)s %(levelname)s %(message)s"))
    root.addHandler(fh)

_shutdown = False


def _handle_signal(signum, frame):
    global _shutdown
    _shutdown = True


# ── Config ────────────────────────────────────────────────────────────────

def load_config():
    try:
        with open(CONFIG_PATH) as f:
            return yaml.safe_load(f)
    except Exception as e:
        log.error("Failed to load config: %s", e)
        return None


# ── GitHub API ────────────────────────────────────────────────────────────

def gh_api(endpoint, paginate=False):
    cmd = ["gh", "api", "--paginate" if paginate else None, endpoint]
    cmd = [c for c in cmd if c is not None]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0:
            log.warning("gh api %s failed: %s", endpoint, result.stderr.strip())
            return None
        return json.loads(result.stdout)
    except (subprocess.TimeoutExpired, json.JSONDecodeError) as e:
        log.warning("gh api %s error: %s", endpoint, e)
        return None


def gh_graphql(query):
    cmd = ["gh", "api", "graphql", "-f", f"query={query}"]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0:
            log.warning("graphql failed: %s", result.stderr.strip())
            return None
        return json.loads(result.stdout)
    except (subprocess.TimeoutExpired, json.JSONDecodeError) as e:
        log.warning("graphql error: %s", e)
        return None



def get_resolved_comment_ids(repo, pr_number):
    """Return set of comment databaseIds whose review threads are already resolved."""
    owner, name = repo.split("/")
    query = (
        '{ repository(owner:"%s",name:"%s") { pullRequest(number:%s) '
        '{ reviewThreads(first:100) { nodes { isResolved comments(first:1) '
        '{ nodes { databaseId } } } } } } }' % (owner, name, pr_number)
    )
    data = gh_graphql(query)
    if not data:
        return set()
    resolved = set()
    try:
        threads = data["data"]["repository"]["pullRequest"]["reviewThreads"]["nodes"]
        for t in threads:
            if t["isResolved"] and t["comments"]["nodes"]:
                resolved.add(t["comments"]["nodes"][0]["databaseId"])
    except (KeyError, TypeError):
        pass
    return resolved


# ── Cursors (track what we've already processed) ──────────────────────────

def load_cursors():
    try:
        with open(CURSOR_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def save_cursors(cursors):
    tmp = CURSOR_FILE.with_suffix(".tmp")
    with open(tmp, "w") as f:
        json.dump(cursors, f, indent=2)
    tmp.rename(CURSOR_FILE)


# ── Event log ─────────────────────────────────────────────────────────────

def load_processed_ids():
    ids = set()
    try:
        with open(EVENT_LOG) as f:
            for line in f:
                try:
                    ev = json.loads(line)
                    key = ev.get("idempotency_key")
                    if key:
                        ids.add(key)
                except json.JSONDecodeError:
                    continue
    except FileNotFoundError:
        pass
    return ids


def log_event(event):
    event["ts"] = datetime.now(timezone.utc).isoformat()
    with open(EVENT_LOG, "a") as f:
        f.write(json.dumps(event, separators=(",", ":")) + "\n")


# ── tmux pane routing ─────────────────────────────────────────────────────

def list_labeled_panes():
    """Return list of (pane_id, label, command, mode, cwd) tuples."""
    try:
        result = subprocess.run(
            ["tmux", "list-panes", "-a", "-F",
             "#{pane_id}\t#{@label}\t#{pane_current_command}\t#{pane_mode}\t#{pane_current_path}"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode != 0:
            return []
        panes = []
        for line in result.stdout.strip().split("\n"):
            if not line:
                continue
            parts = line.split("\t")
            if len(parts) >= 5:
                panes.append((parts[0], parts[1], parts[2], parts[3], parts[4]))
        return panes
    except Exception:
        return []


def _label_matches_branch(label, branch):
    if not label:
        return False
    if label == branch:
        return True
    branch_leaf = branch.split("/")[-1]
    label_leaf = label.split("/")[-1]
    # Full form either side
    if label.endswith("/" + branch) or branch.endswith("/" + label):
        return True
    # Leaf match — e.g. label="experimental-ledger", branch="jcl/experimental-ledger"
    if label == branch_leaf or label_leaf == branch_leaf:
        return True
    # Path-based label (e.g., /data/worktrees/jcl/foo) ending with branch leaf
    if label.endswith("/" + branch_leaf):
        return True
    return False


def _cwd_matches_branch(cwd, branch):
    """Verify the pane's cwd is plausibly within a worktree (any worktree).
    Guards against stale labels on panes that moved to /home or /tmp etc.
    We trust the label to identify the specific branch — this check just
    rejects panes that clearly aren't in a worktree at all."""
    if not cwd:
        return False
    return cwd.startswith("/data/worktrees/") or cwd.startswith("/data/cjob/worktrees/")


def find_pane_for_branch(branch, head_sha=None):
    """Find an injectable Claude pane for the branch.
    Returns pane_id or None. Requires pane running claude, not in copy-mode,
    and with cwd consistent with the branch (guards against stale labels).
    If head_sha is provided and label matching fails, falls back to checking
    if any pane's worktree HEAD matches the SHA (handles renamed branches)."""
    panes = list_labeled_panes()
    for pid, label, cmd, mode, cwd in panes:
        if cmd != "claude" or mode != "":
            continue
        if not _label_matches_branch(label, branch):
            continue
        if not _cwd_matches_branch(cwd, branch):
            continue
        return pid
    # Fallback: match by git HEAD SHA if label matching failed
    if head_sha:
        for pid, label, cmd, mode, cwd in panes:
            if cmd != "claude" or mode != "":
                continue
            if not _cwd_matches_branch(cwd, ""):
                # Check cwd is under /data/worktrees/
                if not cwd or not cwd.startswith("/data/worktrees/"):
                    continue
            # Resolve git HEAD in pane's cwd
            try:
                wt_root = cwd
                result = subprocess.run(
                    ["git", "-C", wt_root, "rev-parse", "HEAD"],
                    capture_output=True, text=True, timeout=5,
                )
                if result.returncode == 0 and result.stdout.strip() == head_sha:
                    log.info("SHA fallback matched pane %s (label=%s) for branch %s", pid, label, branch)
                    return pid
            except Exception:
                continue
    return None


def any_pane_labeled_for_branch(branch, head_sha=None):
    """Return a pane_id if any pane (regardless of state) has a label matching
    the branch AND a cwd consistent with it. Falls back to SHA matching.
    Used to decide whether to defer vs. spawn a fresh tangent."""
    panes = list_labeled_panes()
    for pid, label, cmd, mode, cwd in panes:
        if not _label_matches_branch(label, branch):
            continue
        if not _cwd_matches_branch(cwd, branch):
            continue
        return pid
    if head_sha:
        for pid, label, cmd, mode, cwd in panes:
            if not cwd or not cwd.startswith("/data/worktrees/"):
                continue
            try:
                result = subprocess.run(
                    ["git", "-C", cwd, "rev-parse", "HEAD"],
                    capture_output=True, text=True, timeout=5,
                )
                if result.returncode == 0 and result.stdout.strip() == head_sha:
                    return pid
            except Exception:
                continue
    return None


def is_pane_idle(pane_id):
    """Check if a Claude pane is at the input prompt (idle).
    Works regardless of pane size by checking the last '❯' prompt line.
    Idle = last ❯ line has no text after it (empty input buffer).
    Busy = 'esc to interrupt' visible, or ❯ has text (queued input)."""
    try:
        result = subprocess.run(
            ["tmux", "capture-pane", "-t", pane_id, "-p"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode != 0:
            return False
        content = result.stdout
        if "esc to interrupt" in content:
            return False
        # Find the last line with the ❯ prompt
        lines = content.rstrip("\n").split("\n")
        for line in reversed(lines):
            stripped = line.strip()
            if "❯" in stripped:
                # ❯ alone (possibly with decorators) = idle
                # ❯ followed by text = input queued, not idle
                after_prompt = stripped.split("❯", 1)[1].strip()
                return after_prompt == ""
        return False
    except Exception:
        return False


_injected_this_tick = set()


def inject_into_pane(pane_id, message):
    """Send a message to a Claude session in a tmux pane.
    Uses send-keys -l (literal) to type the message, then Enter to submit.
    paste-buffer doesn't work because bracketed paste prevents submission.
    Retries Enter if the first attempt doesn't trigger processing.
    Only one injection per pane per tick to avoid stacking."""
    if pane_id in _injected_this_tick:
        log.info("Skipping injection into %s — already injected this tick", pane_id)
        return False
    try:
        msg = message.replace("\n", " ")
        subprocess.run(
            ["tmux", "send-keys", "-t", pane_id, "-l", msg],
            check=True, timeout=10,
        )
        # Scale delay with message length — long messages need more time
        # for tmux to feed all characters through the PTY
        delay = max(0.5, len(msg) / 500)
        time.sleep(delay)
        subprocess.run(
            ["tmux", "send-keys", "-t", pane_id, "Enter"],
            check=True, timeout=5,
        )
        # Verify Claude started processing (no longer idle).
        # If still idle after 2s, the Enter was swallowed — retry.
        time.sleep(2)
        if is_pane_idle(pane_id):
            log.warning("Enter may have been dropped for pane %s — retrying", pane_id)
            subprocess.run(
                ["tmux", "send-keys", "-t", pane_id, "Enter"],
                check=True, timeout=5,
            )
        _injected_this_tick.add(pane_id)
        return True
    except Exception as e:
        log.warning("inject failed for pane %s: %s", pane_id, e)
        return False


# ── Tangent spawning ──────────────────────────────────────────────────────

AIFSDK_DIR = Path.home() / "aifsdk"


WORKTREE_ROOT = Path("/data/worktrees")
_spawns_this_tick = 0
MAX_SPAWNS_PER_TICK = 1


def spawn_tangent(branch, prompt):
    """Spawn a tangent for the given branch. Returns True on success.
    If the branch's worktree exists at a non-standard path, creates a
    symlink at the expected path and retries tangent for correct layout.
    Limited to MAX_SPAWNS_PER_TICK to avoid layout drift."""
    global _spawns_this_tick
    if _spawns_this_tick >= MAX_SPAWNS_PER_TICK:
        log.info("Spawn budget exhausted (%d/%d) — deferring %s to next tick",
                 _spawns_this_tick, MAX_SPAWNS_PER_TICK, branch)
        return False
    try:
        result = subprocess.run(
            [str(TANGENT), branch, prompt],
            timeout=30,
            capture_output=True, text=True,
            cwd=str(AIFSDK_DIR),
        )
        if result.returncode == 0:
            _spawns_this_tick += 1
            return True
        stderr = result.stderr.strip()
        log.warning("tangent failed for %s: %s", branch, stderr)

        # If worktree exists at a different path, symlink and retry
        wt_result = subprocess.run(
            ["git", "-C", str(AIFSDK_DIR), "worktree", "list", "--porcelain"],
            capture_output=True, text=True, timeout=10,
        )
        wt_path = None
        current_path = None
        for line in wt_result.stdout.split("\n"):
            if line.startswith("worktree "):
                current_path = line[len("worktree "):]
            elif line.startswith("branch refs/heads/"):
                wt_branch = line[len("branch refs/heads/"):]
                if wt_branch == branch and current_path:
                    wt_path = current_path
                    break

        if not wt_path:
            log.error("No worktree found for branch %s", branch)
            return False

        expected = WORKTREE_ROOT / branch
        if not expected.exists() and wt_path:
            log.info(
                "Worktree for %s at %s — symlinking to %s for tangent",
                branch, wt_path, expected,
            )
            expected.parent.mkdir(parents=True, exist_ok=True)
            expected.symlink_to(wt_path)

        # Retry tangent — it will see the directory and use its layout
        result2 = subprocess.run(
            [str(TANGENT), branch, prompt],
            timeout=30,
            capture_output=True, text=True,
            cwd=str(AIFSDK_DIR),
        )
        if result2.returncode == 0:
            _spawns_this_tick += 1
            return True
        log.error("tangent retry failed for %s: %s", branch, result2.stderr.strip())
        return False
    except Exception as e:
        log.error("spawn_tangent failed for %s: %s", branch, e)
        return False


# ── Inbox (for unrouted comments) ────────────────────────────────────────

def write_inbox(entry):
    with open(INBOX_FILE, "a") as f:
        f.write(f"[{datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M')}] {entry}\n")


# ── Mode A: PR comment routing ───────────────────────────────────────────

def format_comment_summary(comment):
    body = comment["body"].replace("\n", " ").strip()
    if len(body) > 300:
        body = body[:297] + "..."
    path = comment.get("path", "")
    line = comment.get("line") or comment.get("original_line") or ""
    location = f"{path}:{line}" if path else ""
    return f"[{location}] {body}" if location else body


def format_batched_injection(comments, pr_number, repo):
    commenter = comments[0]["user"]["login"]
    n = len(comments)
    header = (
        f"[PR Daemon] {n} new review comment{'s' if n > 1 else ''} "
        f"on PR #{pr_number} ({repo}) from @{commenter}:"
    )
    items = []
    for c in comments[:15]:
        items.append(f"  - {format_comment_summary(c)}")
    if n > 15:
        items.append(f"  ... and {n - 15} more")
    footer = (
        "Assess each comment. Address valid ones (edit + commit + push), "
        "then resolve each review thread on GitHub. "
        "If any are unclear or wrong, tell me which and why."
    )
    return header + " " + " | ".join(items) + " — " + footer


def format_human_review(comments, pr_number, repo):
    commenter = comments[0]["user"]["login"]
    n = len(comments)
    header = (
        f"[PR Daemon] {n} new review comment{'s' if n > 1 else ''} "
        f"on PR #{pr_number} ({repo}) from @{commenter} (human reviewer):"
    )
    items = []
    for c in comments[:15]:
        items.append(f"  - {format_comment_summary(c)}")
    if n > 15:
        items.append(f"  ... and {n - 15} more")
    footer = (
        "Review these human comments carefully. Summarize what the reviewer "
        "is asking for, then propose how to address each point. "
        "DO NOT make changes or resolve threads — just present the summary "
        "and your proposed response so I can decide."
    )
    return header + " " + " | ".join(items) + " — " + footer


def poll_review_comments(repo, cursors, processed_ids, config):
    """Poll for new review comments on PRs authored by pr_author.
    Batches comments per-PR to avoid injecting one at a time."""
    pr_author = config.get("pr_author", "JohnLangford")
    shadow = config.get("shadow", False)


    cursor_key = f"{repo}/review_comments"
    since = cursors.get(cursor_key)
    since_param = f"&since={since}" if since else ""

    comments = gh_api(
        f"/repos/{repo}/pulls/comments?sort=updated&direction=desc&per_page=100{since_param}",
        paginate=False,
    )
    if not comments:
        return

    new_cursor = since
    # Group new comments by PR
    by_pr = {}
    for comment in comments:
        comment_id = comment["id"]
        updated_at = comment["updated_at"]
        idem_key = f"review:{comment_id}:{updated_at}"

        if idem_key in processed_ids:
            continue

        if new_cursor is None or updated_at > new_cursor:
            new_cursor = updated_at

        pr_url = comment.get("pull_request_url", "")
        pr_number = pr_url.rstrip("/").split("/")[-1] if pr_url else None
        if not pr_number:
            continue

        pr_data = _get_pr_data(repo, pr_number)
        if not pr_data:
            continue
        if pr_data.get("state") != "open":
            processed_ids.add(idem_key)
            continue
        if pr_data["user"]["login"] != pr_author:
            processed_ids.add(idem_key)
            continue
        if comment["user"]["login"] == pr_author:
            processed_ids.add(idem_key)
            continue

        if pr_number not in by_pr:
            by_pr[pr_number] = {
                "branch": pr_data["head"]["ref"],
                "head_sha": pr_data["head"]["sha"],
                "comments": [],
                "idem_keys": [],
            }
        by_pr[pr_number]["comments"].append(comment)
        by_pr[pr_number]["idem_keys"].append(idem_key)

    # Process each PR's batch
    protected = _scheduled_branches(config)
    for pr_number, batch in by_pr.items():
        branch = batch["branch"]
        head_sha = batch.get("head_sha")
        if branch in protected and not _is_health_allowed(branch, config):
            processed_ids.update(batch["idem_keys"])
            continue
        comments_list = batch["comments"]
        idem_keys = batch["idem_keys"]

        # Filter out comments whose review threads are already resolved
        resolved_ids = get_resolved_comment_ids(repo, pr_number)
        filtered = [
            (c, k) for c, k in zip(comments_list, idem_keys)
            if c["id"] not in resolved_ids
        ]
        already_resolved = len(comments_list) - len(filtered)
        if already_resolved > 0:
            resolved_keys = [
                k for c, k in zip(comments_list, idem_keys)
                if c["id"] in resolved_ids
            ]
            for k in resolved_keys:
                processed_ids.add(k)
            log.info(
                "PR #%s: %d/%d comments already resolved — skipped",
                pr_number, already_resolved, len(comments_list),
            )
        if not filtered:
            continue
        comments_list = [c for c, k in filtered]
        idem_keys = [k for c, k in filtered]

        commenter = comments_list[0]["user"]["login"]
        is_bot = (
            comments_list[0]["user"].get("type") == "Bot"
            or commenter.endswith("[bot]")
        )
        is_self = commenter == pr_author
        if is_self:
            processed_ids.update(idem_keys)
            continue
        auto_address = is_bot

        log.info(
            "%d new unresolved comment(s) on PR #%s (%s) by @%s [%s]",
            len(comments_list), pr_number, repo, commenter,
            "bot" if is_bot else "human",
        )

        events = [{
            "mode": "A",
            "repo": repo,
            "pr": pr_number,
            "comment_count": len(comments_list),
            "commenter": commenter,
            "is_bot": is_bot,
            "idempotency_key": k,
        } for k in idem_keys]

        if shadow:
            for ev in events:
                ev["action"] = "shadow"
                log_event(ev)
            processed_ids.update(idem_keys)
            continue

        if not auto_address:
            # Human comments: review + summarize + propose, but don't resolve
            human_msg = format_human_review(comments_list, pr_number, repo)
            pane_id = find_pane_for_branch(branch, head_sha=head_sha)
            acted = False
            if pane_id and is_pane_idle(pane_id):
                acted = inject_into_pane(pane_id, human_msg)
            elif pane_id is None:
                acted = spawn_tangent(branch, human_msg)
            if acted:
                for ev in events:
                    ev["action"] = "human_review"
                    log_event(ev)
                log.info(
                    "Human review triggered for @%s on PR #%s (%s)",
                    commenter, pr_number, branch,
                )
            else:
                for ev in events:
                    ev["action"] = "human_deferred"
                    log_event(ev)
                log.info(
                    "Human comment by @%s deferred — pane busy or spawn failed",
                    commenter,
                )
                continue  # don't mark processed — retry next tick
            processed_ids.update(idem_keys)
            continue

        pane_id = find_pane_for_branch(branch, head_sha=head_sha)

        if pane_id is None:
            prompt = (
                f"Address the {len(comments_list)} unresolved Copilot review "
                f"comment(s) on PR #{pr_number} in {repo}. "
                f"For each unresolved thread: read the comment, assess if "
                f"it's valid, and if so make the fix. After addressing all "
                f"comments, commit, push, and resolve each thread on GitHub."
            )
            spawned = spawn_tangent(branch, prompt)
            if spawned:
                for ev in events:
                    ev["action"] = "tangent_spawned"
                    log_event(ev)
                log.info(
                    "Spawned tangent for %s — %d unresolved comments on PR #%s",
                    branch, len(comments_list), pr_number,
                )
                processed_ids.update(idem_keys)
            else:
                log.warning(
                    "Tangent spawn failed for %s — %d comments will retry next tick",
                    branch, len(comments_list),
                )
            continue

        if not is_pane_idle(pane_id):
            log.info(
                "Pane %s for %s is busy — %d comments deferred to next tick",
                pane_id, branch, len(comments_list),
            )
            continue

        msg = format_batched_injection(comments_list, pr_number, repo)
        if inject_into_pane(pane_id, msg):
            for ev in events:
                ev["action"] = "injected"
                ev["pane"] = pane_id
                log_event(ev)
            log.info("Injected %d comments into pane %s for %s", len(comments_list), pane_id, branch)
        else:
            for ev in events:
                ev["action"] = "inject_failed"
                ev["pane"] = pane_id
                log_event(ev)
            write_inbox(
                f"PR #{pr_number} ({repo}) inject failed for pane {pane_id}: "
                f"{len(comments_list)} comments by @{commenter}"
            )

        processed_ids.update(idem_keys)

    if new_cursor:
        cursors[cursor_key] = new_cursor


# ── Mode A: PR review submissions (CHANGES_REQUESTED, COMMENTED) ─────────

def poll_pr_reviews(repo, cursors, processed_ids, config):
    """Poll for new review submissions (the 'Submit review' body, not inline
    comments) on open jcl-authored PRs. These come from the pulls/reviews
    endpoint which is separate from pulls/comments."""
    pr_author = config.get("pr_author", "JohnLangford")
    shadow = config.get("shadow", False)
    protected = _scheduled_branches(config)

    prs = gh_api(
        f"/repos/{repo}/pulls?state=open&sort=updated&direction=desc&per_page=20",
    )
    if not prs:
        return

    for pr in prs:
        if pr["user"]["login"] != pr_author:
            continue
        pr_number = pr["number"]
        branch = pr["head"]["ref"]
        head_sha = pr["head"]["sha"]

        if branch in protected and not _is_health_allowed(branch, config):
            continue

        reviews = gh_api(f"/repos/{repo}/pulls/{pr_number}/reviews")
        if not reviews:
            continue

        for review in reviews:
            state = review.get("state", "")
            if state not in ("CHANGES_REQUESTED", "COMMENTED"):
                continue
            body = (review.get("body") or "").strip()
            if not body:
                continue

            review_id = review["id"]
            submitted_at = review.get("submitted_at", "")
            reviewer = review["user"]["login"]

            if reviewer == pr_author:
                continue

            idem_key = f"pr_review:{repo}:{pr_number}:{review_id}"
            if idem_key in processed_ids:
                continue

            is_bot = (
                review["user"].get("type") == "Bot"
                or reviewer.endswith("[bot]")
            )
            auto_address = is_bot

            log.info(
                "PR review on #%s (%s) by @%s [%s]: %s",
                pr_number, repo, reviewer, state, body[:60],
            )

            if shadow:
                log_event({
                    "mode": "A", "repo": repo, "pr": pr_number,
                    "commenter": reviewer, "action": "shadow",
                    "idempotency_key": idem_key,
                })
                processed_ids.add(idem_key)
                continue

            body_short = body.replace("\n", " ")
            if len(body_short) > 400:
                body_short = body_short[:397] + "..."

            if auto_address:
                msg = (
                    f"[PR Daemon] Review on PR #{pr_number} ({repo}) from "
                    f"@{reviewer} [{state}]: \"{body_short}\" — "
                    f"Address this review feedback, then commit and push."
                )
            else:
                msg = (
                    f"[PR Daemon] Review on PR #{pr_number} ({repo}) from "
                    f"@{reviewer} (human reviewer) [{state}]: \"{body_short}\" — "
                    f"Review this feedback carefully. Summarize what the "
                    f"reviewer is asking for and propose how to address it. "
                    f"DO NOT make changes or resolve threads — just present "
                    f"your summary and proposed response so I can decide."
                )

            pane_id = find_pane_for_branch(branch, head_sha=head_sha)
            if pane_id and is_pane_idle(pane_id):
                if inject_into_pane(pane_id, msg):
                    log_event({
                        "mode": "A", "repo": repo, "pr": pr_number,
                        "commenter": reviewer, "action": "review_injected",
                        "idempotency_key": idem_key,
                    })
                    processed_ids.add(idem_key)
                else:
                    continue  # retry next tick
            elif pane_id is None:
                if spawn_tangent(branch, msg):
                    log_event({
                        "mode": "A", "repo": repo, "pr": pr_number,
                        "commenter": reviewer, "action": "review_spawned",
                        "idempotency_key": idem_key,
                    })
                    processed_ids.add(idem_key)
                else:
                    log.warning("Review injection deferred for PR #%s — no pane, spawn failed", pr_number)
            else:
                continue  # pane busy — retry next tick


_pr_cache = {}
_pr_not_found = set()


def _get_pr_data(repo, pr_number):
    key = f"{repo}/{pr_number}"
    if key in _pr_not_found:
        return None
    if key in _pr_cache:
        return _pr_cache[key]
    data = gh_api(f"/repos/{repo}/pulls/{pr_number}")
    if data and "head" in data:
        _pr_cache[key] = data
    else:
        _pr_not_found.add(key)
        data = None
    return data


# ── Mode A: issue comments (top-level PR comments) ───────────────────────

def poll_issue_comments(repo, cursors, processed_ids, config):
    """Poll for new top-level (issue) comments on PRs authored by pr_author.
    Batches comments per-PR."""
    pr_author = config.get("pr_author", "JohnLangford")
    shadow = config.get("shadow", False)


    cursor_key = f"{repo}/issue_comments"
    since = cursors.get(cursor_key)
    since_param = f"&since={since}" if since else ""

    comments = gh_api(
        f"/repos/{repo}/issues/comments?sort=updated&direction=desc&per_page=100{since_param}",
        paginate=False,
    )
    if not comments:
        return

    new_cursor = since
    by_pr = {}
    for comment in comments:
        comment_id = comment["id"]
        updated_at = comment["updated_at"]
        idem_key = f"issue:{comment_id}:{updated_at}"

        if idem_key in processed_ids:
            continue

        if new_cursor is None or updated_at > new_cursor:
            new_cursor = updated_at

        issue_url = comment.get("issue_url", "")
        issue_number = issue_url.rstrip("/").split("/")[-1] if issue_url else None
        if not issue_number:
            continue

        pr_data = _get_pr_data(repo, issue_number)
        if not pr_data or "head" not in pr_data:
            processed_ids.add(idem_key)
            continue
        if pr_data.get("state") != "open":
            processed_ids.add(idem_key)
            continue
        if pr_data["user"]["login"] != pr_author:
            processed_ids.add(idem_key)
            continue
        if comment["user"]["login"] == pr_author:
            processed_ids.add(idem_key)
            continue

        if issue_number not in by_pr:
            by_pr[issue_number] = {
                "branch": pr_data["head"]["ref"],
                "comments": [],
                "idem_keys": [],
            }
        by_pr[issue_number]["comments"].append(comment)
        by_pr[issue_number]["idem_keys"].append(idem_key)

    protected = _scheduled_branches(config)
    for pr_number, batch in by_pr.items():
        branch = batch["branch"]
        head_sha = batch.get("head_sha")
        if branch in protected and not _is_health_allowed(branch, config):
            processed_ids.update(batch["idem_keys"])
            continue
        comments_list = batch["comments"]
        idem_keys = batch["idem_keys"]
        commenter = comments_list[0]["user"]["login"]
        is_bot = (
            comments_list[0]["user"].get("type") == "Bot"
            or commenter.endswith("[bot]")
        )
        is_self = commenter == pr_author
        if is_self:
            processed_ids.update(idem_keys)
            continue
        auto_address = is_bot

        log.info(
            "%d new issue comment(s) on PR #%s (%s) by @%s",
            len(comments_list), pr_number, repo, commenter,
        )

        events = [{
            "mode": "A",
            "repo": repo,
            "pr": pr_number,
            "comment_count": len(comments_list),
            "commenter": commenter,
            "is_bot": is_bot,
            "idempotency_key": k,
            "comment_type": "issue",
        } for k in idem_keys]

        if shadow:
            for ev in events:
                ev["action"] = "shadow"
                log_event(ev)
            processed_ids.update(idem_keys)
            continue

        if not auto_address:
            bodies = []
            for c in comments_list[:10]:
                b = c["body"].replace("\n", " ").strip()
                if len(b) > 300:
                    b = b[:297] + "..."
                bodies.append(f"\"{b}\"")
            human_msg = (
                f"[PR Daemon] {len(comments_list)} comment(s) on PR #{pr_number} "
                f"({repo}) from @{commenter} (human reviewer): "
                f"{' | '.join(bodies)} — "
                f"Review these comments carefully. Summarize what the reviewer "
                f"is asking for and propose how to address each point. "
                f"DO NOT make changes or resolve threads — just present "
                f"the summary and your proposed response so I can decide."
            )
            pane_id = find_pane_for_branch(branch, head_sha=head_sha)
            acted = False
            if pane_id and is_pane_idle(pane_id):
                acted = inject_into_pane(pane_id, human_msg)
            elif pane_id is None:
                acted = spawn_tangent(branch, human_msg)
            if acted:
                for ev in events:
                    ev["action"] = "human_review"
                    log_event(ev)
                log.info(
                    "Human review triggered for @%s on PR #%s",
                    commenter, pr_number,
                )
            else:
                for ev in events:
                    ev["action"] = "human_deferred"
                    log_event(ev)
                log.info(
                    "Human issue comment by @%s deferred — pane busy or spawn failed",
                    commenter,
                )
                continue
            processed_ids.update(idem_keys)
            continue

        pane_id = find_pane_for_branch(branch, head_sha=head_sha)

        if pane_id is None:
            for ev in events:
                ev["action"] = "inbox"
                ev["reason"] = f"no pane for branch {branch}"
                log_event(ev)
            processed_ids.update(idem_keys)
            write_inbox(
                f"PR #{pr_number} ({repo}) {len(comments_list)} issue comments "
                f"by @{commenter} — no pane for {branch}"
            )
            continue

        if not is_pane_idle(pane_id):
            log.info(
                "Pane %s for %s is busy — %d issue comments deferred",
                pane_id, branch, len(comments_list),
            )
            continue

        bodies = []
        for c in comments_list[:10]:
            b = c["body"].replace("\n", " ").strip()
            if len(b) > 300:
                b = b[:297] + "..."
            bodies.append(b)
        items = " | ".join(f"\"{b}\"" for b in bodies)
        msg = (
            f"[PR Daemon] {len(comments_list)} comment(s) on PR #{pr_number} "
            f"({repo}) from @{commenter}: {items} — "
            f"Assess and address if valid, then resolve. "
            f"If unclear or wrong, just tell me."
        )

        if inject_into_pane(pane_id, msg):
            for ev in events:
                ev["action"] = "injected"
                ev["pane"] = pane_id
                log_event(ev)
        else:
            for ev in events:
                ev["action"] = "inject_failed"
                log_event(ev)
            write_inbox(
                f"PR #{pr_number} ({repo}) inject failed: "
                f"{len(comments_list)} comments by @{commenter}"
            )

        processed_ids.update(idem_keys)

    if new_cursor:
        cursors[cursor_key] = new_cursor


# ── Mode A: Failing checks detection ──────────────────────────────────────

ET = ZoneInfo("America/New_York")


def _scheduled_branches(config):
    """Return set of branches managed by Mode C's merge schedule.
    These should only change via their scheduled merge, not via Mode A/B.
    Exception: semantic/control allows PR health checks during its
    maintenance window (midnight-4am ET)."""
    return {m["target"] for m in config.get("mode_c", {}).get("merges", [])}


def _is_critic_due(base_branch, config, cursors):
    """Check if a scheduled Mode B critic should fire for a protected base branch.
    Fires once per day at the configured hour/minute (ET)."""
    windows = config.get("mode_c", {}).get("maintenance_windows", {})
    window = windows.get(base_branch)
    if not window or "critic_hour" not in window:
        return False
    now_et = datetime.now(ET)
    cursor_key = f"critic_scheduled/{base_branch}"
    last_run = cursors.get(cursor_key, 0)
    last_dt = datetime.fromtimestamp(last_run, tz=ET) if last_run else None
    # Already ran today?
    if last_dt and last_dt.date() >= now_et.date():
        return False
    # Are we past the scheduled time?
    target_hour = window["critic_hour"]
    target_minute = window.get("critic_minute", 0)
    if now_et.hour > target_hour or (now_et.hour == target_hour and now_et.minute >= target_minute):
        cursors[cursor_key] = time.time()
        return True
    return False


def _is_health_allowed(branch, config):
    """Check if PR health actions (check fixes, conflict resolution) are
    allowed right now for a scheduled branch. Returns True if the branch
    has a maintenance window and we're inside it."""
    windows = config.get("mode_c", {}).get("maintenance_windows", {})
    window = windows.get(branch)
    if not window:
        return False
    now_et = datetime.now(ET)
    start_hour = window.get("start_hour", 0)
    end_hour = window.get("end_hour", 4)
    return start_hour <= now_et.hour < end_hour


def _route_to_pane_or_tangent(branch, msg, event, processed_ids, head_sha=None):
    """Try to inject msg into a pane for the branch, or spawn a tangent.
    Returns True if acted, False if deferred."""
    pane_id = find_pane_for_branch(branch, head_sha=head_sha)
    if pane_id and is_pane_idle(pane_id):
        if inject_into_pane(pane_id, msg):
            event["action"] = event.get("_action_injected", "injected")
            event["pane"] = pane_id
            log_event(event)
            processed_ids.add(event["idempotency_key"])
            return True
    elif pane_id is None:
        if spawn_tangent(branch, msg):
            event["action"] = event.get("_action_spawned", "spawned")
            log_event(event)
            processed_ids.add(event["idempotency_key"])
            return True
    return False


def poll_pr_health(repo, cursors, processed_ids, config):
    """Detect failing CI checks and merge conflicts on open jcl-authored PRs."""
    pr_author = config.get("pr_author", "JohnLangford")
    shadow = config.get("shadow", False)
    protected = _scheduled_branches(config)

    prs = gh_api(
        f"/repos/{repo}/pulls?state=open&sort=updated&direction=desc&per_page=20",
    )
    if not prs:
        return

    for pr in prs:
        if pr["user"]["login"] != pr_author:
            continue
        pr_number = pr["number"]
        head_sha = pr["head"]["sha"]
        branch = pr["head"]["ref"]
        base = pr["base"]["ref"]

        if branch in protected and not _is_health_allowed(branch, config):
            continue

        # ── Failing checks ────────────────────────────────────────────
        checks = gh_api(f"/repos/{repo}/commits/{head_sha}/check-runs")
        if checks:
            failed = [
                cr for cr in checks.get("check_runs", [])
                if cr.get("conclusion") == "failure"
            ]
            if failed:
                idem_key = f"checks:{repo}:{pr_number}:{head_sha}"
                if not (idem_key in processed_ids and find_pane_for_branch(branch, head_sha=head_sha)):
                    names = [cr["name"] for cr in failed]
                    log.info(
                        "PR #%s (%s) has %d failing check(s): %s",
                        pr_number, repo, len(failed), ", ".join(names),
                    )
                    if not shadow:
                        check_detail = " | ".join(
                            f"{cr['name']}: {cr.get('html_url', 'no url')}" for cr in failed
                        )
                        msg = (
                            f"[PR Daemon] PR #{pr_number} ({repo}) has {len(failed)} failing "
                            f"CI check(s): {check_detail} — "
                            f"Investigate the failures, fix the issues, then commit and push. "
                            f"You can view check logs with: "
                            f"gh run view --repo {repo} --job <job-id> --log-failed"
                        )
                        _route_to_pane_or_tangent(branch, msg, {
                            "mode": "A", "repo": repo, "pr": pr_number,
                            "head_sha": head_sha, "failed_checks": names,
                            "idempotency_key": idem_key,
                            "_action_injected": "check_fix_injected",
                            "_action_spawned": "check_fix_spawned",
                        }, processed_ids, head_sha=head_sha)
                    else:
                        log_event({"mode": "A", "repo": repo, "pr": pr_number,
                                   "action": "shadow", "idempotency_key": idem_key})
                        processed_ids.add(idem_key)

        # ── Merge conflicts ───────────────────────────────────────────
        # The list endpoint returns mergeable=null; fetch individual PR
        # only if we haven't already checked this SHA.
        conflict_key = f"conflict:{repo}:{pr_number}:{head_sha}"
        if conflict_key in processed_ids:
            continue
        pr_detail = gh_api(f"/repos/{repo}/pulls/{pr_number}")
        if not pr_detail:
            continue
        mergeable = pr_detail.get("mergeable")
        mergeable_state = pr_detail.get("mergeable_state")
        if mergeable is False and mergeable_state == "dirty":
            log.info("PR #%s (%s) has merge conflicts with %s", pr_number, repo, base)
            if not shadow:
                msg = (
                    f"[PR Daemon] PR #{pr_number} ({repo}) has merge conflicts "
                    f"with {base}. Merge origin/{base} into your branch and "
                    f"resolve all conflicts, then commit and push."
                )
                if not _route_to_pane_or_tangent(branch, msg, {
                    "mode": "A", "repo": repo, "pr": pr_number,
                    "head_sha": head_sha, "conflict_base": base,
                    "idempotency_key": conflict_key,
                    "_action_injected": "conflict_fix_injected",
                    "_action_spawned": "conflict_fix_spawned",
                }, processed_ids, head_sha=head_sha):
                    continue  # deferred — retry next tick
            else:
                log_event({"mode": "A", "repo": repo, "pr": pr_number,
                           "action": "shadow", "idempotency_key": conflict_key})
                processed_ids.add(conflict_key)
        else:
            # No conflicts — mark as checked so we don't re-fetch this SHA
            processed_ids.add(conflict_key)


# ── Mode B: Patch critic ──────────────────────────────────────────────────

def poll_patch_critic(config, cursors, processed_ids):
    """Monitor configured branches for new PR pushes. Spawn a tangent
    critic for each new head SHA detected."""
    branches = config.get("mode_b", {}).get("branches", [])
    if not branches:
        return

    protected = _scheduled_branches(config)

    for entry in branches:
        repo = entry["repo"]
        base = entry["base"]
        if _shutdown:
            break

        prs = gh_api(
            f"/repos/{repo}/pulls?base={base}&state=open"
            f"&sort=updated&direction=desc&per_page=30",
        )
        if not prs:
            continue

        for pr in prs:
            pr_number = pr["number"]
            head_sha = pr["head"]["sha"]
            author = pr["user"]["login"]
            head_ref = pr["head"]["ref"]
            title = pr["title"]

            # Skip PRs created by the daemon itself (critic/ branches)
            if head_ref.startswith("critic/"):
                continue

            # Skip PRs from branches managed by Mode C merge schedule,
            # unless a scheduled critic window is active for the base branch
            if head_ref in protected:
                continue
            if base in protected:
                if not _is_critic_due(base, config, cursors):
                    continue

            idem_key = f"critic:{repo}:{pr_number}:{head_sha}"
            if idem_key in processed_ids:
                continue

            cursor_key = f"{repo}/critic/{pr_number}"
            prev_sha = cursors.get(cursor_key)

            if prev_sha == head_sha:
                processed_ids.add(idem_key)
                continue

            is_new_pr = prev_sha is None
            cursors[cursor_key] = head_sha
            is_self = author == config.get("pr_author", "JohnLangford")

            log.info(
                "Mode B: %s on PR #%s (%s) %s by @%s — %s",
                "new PR" if is_new_pr else "new push",
                pr_number, repo, head_ref, author, title[:60],
            )

            if config.get("shadow"):
                log_event({
                    "mode": "B",
                    "repo": repo,
                    "pr": pr_number,
                    "head_sha": head_sha,
                    "author": author,
                    "action": "shadow",
                    "idempotency_key": idem_key,
                })
                processed_ids.add(idem_key)
                continue

            if is_self:
                prompt = (
                    f"Review PR #{pr_number} in {repo}: \"{title}\". "
                    f"Branch {head_ref} targeting {base}. "
                    f"Run: gh pr diff {pr_number} --repo {repo} "
                    f"to read the full diff. Also read the PR description with: "
                    f"gh pr view {pr_number} --repo {repo} "
                    f"Critique for correctness, design, test coverage, "
                    f"performance, throughput, security, and backward "
                    f"compatibility. Also flag any more elegant alternative "
                    f"approach that accomplishes the same thing. "
                    f"For any substantive issues you find, fix them directly "
                    f"— edit the code, commit, and push. Skip style nits."
                )
            else:
                prompt = (
                    f"Review PR #{pr_number} in {repo}: \"{title}\" by @{author}. "
                    f"Branch {head_ref} targeting {base}. "
                    f"Run: gh pr diff {pr_number} --repo {repo} "
                    f"to read the full diff. Also read the PR description with: "
                    f"gh pr view {pr_number} --repo {repo} "
                    f"Critique the patch for correctness, design, test coverage, "
                    f"performance, throughput, security, and backward "
                    f"compatibility. Also flag any more elegant alternative "
                    f"approach that accomplishes the same thing. "
                    f"Then post your review as a PR comment with: "
                    f"gh pr comment {pr_number} --repo {repo} --body \"<your review>\". "
                    f"Start the comment with \"This is John's reviewbot.\" "
                    f"Be concise and constructive. Focus on substantive issues, "
                    f"not style nits."
                )

            # Prefer injecting into an existing pane. Check both the head_ref
            # label (self-authored case, or critic pane that got re-labeled
            # after checking out the PR branch) and the critic branch label
            # (fresh critic pane).
            acted = False
            action = None
            branch_name = f"critic/{repo.split('/')[1]}-{pr_number}"

            # Candidate labels to check, in order
            candidates = [head_ref, branch_name]
            injectable_pane = None
            labeled_pane = None
            for cand in candidates:
                if injectable_pane is None:
                    injectable_pane = find_pane_for_branch(cand)
                if labeled_pane is None:
                    labeled_pane = any_pane_labeled_for_branch(cand)

            if injectable_pane and is_pane_idle(injectable_pane):
                if inject_into_pane(injectable_pane, f"[PR Daemon] {prompt}"):
                    acted = True
                    action = "critic_injected"
                    log.info("Mode B: injected critic into pane %s for PR #%s", injectable_pane, pr_number)
            elif labeled_pane:
                log.info(
                    "Mode B: pane %s for PR #%s not ready — critic deferred",
                    labeled_pane, pr_number,
                )
                if prev_sha is not None:
                    cursors[cursor_key] = prev_sha
                else:
                    cursors.pop(cursor_key, None)
                continue

            if not acted:
                if spawn_tangent(branch_name, prompt):
                    acted = True
                    action = "critic_spawned"
                    log.info("Mode B: spawned critic for PR #%s (%s)", pr_number, repo)

            if acted:
                log_event({
                    "mode": "B",
                    "repo": repo,
                    "pr": pr_number,
                    "head_sha": head_sha,
                    "author": author,
                    "action": action,
                    "idempotency_key": idem_key,
                })
                processed_ids.add(idem_key)
            else:
                log_event({
                    "mode": "B",
                    "repo": repo,
                    "pr": pr_number,
                    "head_sha": head_sha,
                    "author": author,
                    "action": "critic_failed",
                    "idempotency_key": idem_key,
                })
                log.error("Mode B: failed to spawn critic for PR #%s", pr_number)
                # Roll back cursor so we retry next tick
                if prev_sha is not None:
                    cursors[cursor_key] = prev_sha
                else:
                    cursors.pop(cursor_key, None)


# ── Mode C: merge cascade ─────────────────────────────────────────────────

PST = ZoneInfo("America/Los_Angeles")


def is_schedule_due(schedule, cursor_key, cursors):
    """Check if a merge schedule is due. Returns True if it's time to merge.
    Schedules: 'each_tick', 'daily' (midnight PST), 'weekly' (midnight Saturday PST)."""
    now_pst = datetime.now(PST)
    last_run = cursors.get(cursor_key, 0)
    last_dt = datetime.fromtimestamp(last_run, tz=PST) if last_run else None

    if schedule == "each_tick":
        return True
    elif schedule == "daily":
        if last_dt and last_dt.date() >= now_pst.date():
            return False
        return now_pst.hour >= 0  # after midnight PST
    elif schedule == "weekly":
        if last_dt and (now_pst - last_dt).days < 6:
            return False
        return now_pst.weekday() == 5 and now_pst.hour >= 0  # Saturday
    return False


def check_merge_cascade(config, cursors):
    """Mode C: cascading merges across control branches."""
    merges = config.get("mode_c", {}).get("merges", [])
    if not merges:
        return

    for entry in merges:
        if _shutdown:
            break

        repo = entry["repo"]
        target = entry["target"]
        source = entry["source"]
        schedule = entry.get("schedule", "daily")
        benchmark = entry.get("benchmark", {})
        worktree = entry.get("worktree", "")

        cursor_key = f"mode_c/{repo}/{target}"

        if not is_schedule_due(schedule, cursor_key, cursors):
            continue

        # Respect maintenance window if configured for this target
        if target in _scheduled_branches(config) and not _is_health_allowed(target, config):
            if schedule == "each_tick":
                continue  # defer until inside the window

        # Check if source is ahead of target
        compare = gh_api(f"/repos/{repo}/compare/{target}...{source}")
        if not compare:
            continue

        ahead = compare.get("ahead_by", 0)
        if ahead == 0:
            log.info("Mode C: %s is up to date with %s", target, source)
            cursors[cursor_key] = time.time()
            continue

        source_sha = compare.get("base_commit", {}).get("sha", "?")[:8]

        log.info(
            "Mode C: %s is %d commits behind %s — schedule=%s",
            target, ahead, source, schedule,
        )

        event = {
            "mode": "C",
            "repo": repo,
            "target": target,
            "source": source,
            "ahead_by": ahead,
            "idempotency_key": f"merge:{repo}:{target}:{source_sha}",
        }

        if config.get("shadow"):
            event["action"] = "shadow"
            log_event(event)
            cursors[cursor_key] = time.time()
            continue

        # Build merge prompt
        wt_path = worktree or f"/data/worktrees/{target.split('/')[-1]}"
        merge_instructions = (
            f"Merge {source} into {target} for {repo}. "
            f"{source} is {ahead} commits ahead. "
            f"cd {wt_path} && "
            f"pre_merge_sha=$(git rev-parse HEAD) && "
            f"git fetch origin && "
            f"git merge origin/{source} --no-edit. "
            f"IMPORTANT: note the pre-merge SHA above — you'll need it to roll "
            f"back if the benchmark fails. "
            f"If conflicts arise: auto-resolve 'already applied' conflicts "
            f"(both sides identical after cherry-pick) by accepting either side. "
            f"For non-trivial conflicts, resolve carefully — check git log to "
            f"understand which side is correct. After resolving, push."
        )

        # Add benchmark instructions if configured
        if benchmark.get("enabled"):
            bench_configs = benchmark.get("configs", [benchmark.get("config", "1b")])
            bench_data = benchmark.get("data", "climbmix")
            branch_short = target.replace("semantic/", "")
            bench_cmds = []
            for c in bench_configs:
                bench_cmds.append(
                    f"/data/worktrees/control/phitrain/scripts/eval/cjob_bench.sh "
                    f"{branch_short} --data {bench_data} --config {c} "
                    f"--workstream phinext --priority p0"
                )
            commit_cmds = []
            for c in bench_configs:
                commit_cmds.append(
                    f"/data/worktrees/control/phitrain/scripts/eval/commit_bench_results.sh "
                    f"{target} completed --config {c}"
                )
            configs_str = "+".join(bench_configs)
            merge_instructions += (
                f" After pushing, enqueue benchmark(s) ({configs_str}): "
                + " ; ".join(bench_cmds) + " . "
                f"Each job will notify this pane on completion. "
                f"If a job completes with status 'completed', run the "
                f"results commit script: " + " ; ".join(commit_cmds) + " . "
                f"The script copies metrics.csv, generates a comparison "
                f"plot vs the previous run, and commits to benchmarks/ on "
                f"the branch. "
                f"IF ANY BENCHMARK FAILS (status 'failed' or 'error' rather "
                f"than 'completed'), ROLL BACK THIS MERGE: "
                f"cd {wt_path} && git reset --hard $pre_merge_sha && "
                f"git push --force-with-lease origin {target}. "
                f"The goal is that {target} only accepts changes that pass "
                f"the benchmark. After rolling back, investigate what broke "
                f"on {source} so it can be fixed there, not here."
            )

        # Prefer injecting into an existing pane for the target branch
        pane_id = find_pane_for_branch(target)
        if pane_id and is_pane_idle(pane_id):
            if inject_into_pane(pane_id, f"[PR Daemon] {merge_instructions}"):
                event["action"] = "merge_injected"
                event["pane"] = pane_id
                cursors[cursor_key] = time.time()
                log.info("Mode C: injected merge into pane %s for %s", pane_id, target)
            else:
                event["action"] = "merge_inject_failed"
        elif pane_id:
            event["action"] = "merge_deferred"
            log.info("Mode C: pane for %s is busy — merge deferred", target)
        else:
            if spawn_tangent(target, merge_instructions):
                event["action"] = "merge_spawned"
                cursors[cursor_key] = time.time()
            else:
                event["action"] = "merge_deferred"

        log_event(event)


# ── Auto-merge: squash-merge PRs that are fully approved ──────────────────

def check_auto_merge(repo, processed_ids, config):
    """Squash-merge open jcl-authored PRs targeting main that have:
    - At least one approval
    - All checks passing
    - All review threads resolved"""
    pr_author = config.get("pr_author", "JohnLangford")

    prs = gh_api(
        f"/repos/{repo}/pulls?state=open&base=main"
        f"&sort=updated&direction=desc&per_page=20",
    )
    if not prs:
        return

    for pr in prs:
        if pr["user"]["login"] != pr_author:
            continue
        pr_number = pr["number"]
        head_sha = pr["head"]["sha"]
        title = pr["title"]

        idem_key = f"automerge:{repo}:{pr_number}:{head_sha}"
        if idem_key in processed_ids:
            continue

        # Check approvals
        reviews = gh_api(f"/repos/{repo}/pulls/{pr_number}/reviews")
        if not reviews:
            continue
        approvals = [r for r in reviews if r.get("state") == "APPROVED"]
        if not approvals:
            continue

        # Check all checks pass
        checks = gh_api(f"/repos/{repo}/commits/{head_sha}/check-runs")
        if not checks:
            continue
        check_runs = checks.get("check_runs", [])
        if not check_runs:
            continue
        failing = [
            cr for cr in check_runs
            if cr.get("status") == "completed"
            and cr.get("conclusion") not in ("success", "skipped", "neutral")
        ]
        pending = [cr for cr in check_runs if cr.get("status") != "completed"]
        if failing or pending:
            continue

        # Check all threads resolved
        owner, name = repo.split("/")
        thread_data = gh_graphql(
            '{ repository(owner:"%s",name:"%s") { pullRequest(number:%s) '
            '{ reviewThreads(first:100) { nodes { isResolved } } } } }'
            % (owner, name, pr_number)
        )
        if not thread_data:
            continue
        try:
            threads = thread_data["data"]["repository"]["pullRequest"]["reviewThreads"]["nodes"]
            unresolved = [t for t in threads if not t["isResolved"]]
        except (KeyError, TypeError):
            continue
        if unresolved:
            continue

        # All conditions met — squash merge
        log.info(
            "Auto-merge: PR #%s (%s) \"%s\" — approved, checks pass, threads resolved",
            pr_number, repo, title[:60],
        )

        if config.get("shadow"):
            log_event({
                "mode": "automerge",
                "repo": repo,
                "pr": pr_number,
                "head_sha": head_sha,
                "action": "shadow",
                "idempotency_key": idem_key,
            })
            processed_ids.add(idem_key)
            continue

        merge_result = gh_api_merge(repo, pr_number)
        if merge_result:
            log.info("Auto-merge: PR #%s merged successfully", pr_number)
            log_event({
                "mode": "automerge",
                "repo": repo,
                "pr": pr_number,
                "head_sha": head_sha,
                "action": "merged",
                "idempotency_key": idem_key,
            })
        else:
            log.error("Auto-merge: PR #%s merge failed", pr_number)
            log_event({
                "mode": "automerge",
                "repo": repo,
                "pr": pr_number,
                "head_sha": head_sha,
                "action": "merge_failed",
                "idempotency_key": idem_key,
            })
        processed_ids.add(idem_key)


def gh_api_merge(repo, pr_number):
    """Squash-merge a PR via the GitHub API."""
    cmd = [
        "gh", "api", "-X", "PUT",
        f"/repos/{repo}/pulls/{pr_number}/merge",
        "-f", "merge_method=squash",
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        if result.returncode != 0:
            log.warning("Merge API failed for PR #%s: %s", pr_number, result.stderr.strip())
            return False
        return True
    except Exception as e:
        log.warning("Merge API error for PR #%s: %s", pr_number, e)
        return False


# ── Issue triage ──────────────────────────────────────────────────────────

def poll_issues(config, cursors, processed_ids):
    """Watch configured repos for new/updated issues. Spawn a tangent
    to triage each one: understand the core issue, assess reproducibility
    and impact, suggest ways to address it, and post a comment."""
    repos = config.get("issue_watch", {}).get("repos", [])
    if not repos:
        return

    for repo in repos:
        if _shutdown:
            break

        cursor_key = f"{repo}/issues"
        since = cursors.get(cursor_key)
        since_param = f"&since={since}" if since else ""

        issues = gh_api(
            f"/repos/{repo}/issues?state=open&sort=updated&direction=desc"
            f"&per_page=20{since_param}",
        )
        if not issues:
            continue

        new_cursor = since
        for issue in issues:
            # Skip PRs (GitHub's issues endpoint includes them)
            if issue.get("pull_request"):
                continue

            issue_number = issue["number"]
            updated_at = issue["updated_at"]
            idem_key = f"issue_triage:{repo}:{issue_number}:{updated_at}"

            if idem_key in processed_ids:
                continue

            if new_cursor is None or updated_at > new_cursor:
                new_cursor = updated_at

            title = issue["title"]
            author = issue["user"]["login"]
            labels = [l["name"] for l in issue.get("labels", [])]

            log.info(
                "New/updated issue #%s (%s) by @%s: %s",
                issue_number, repo, author, title[:60],
            )

            if config.get("shadow"):
                log_event({
                    "mode": "issues",
                    "repo": repo,
                    "issue": issue_number,
                    "action": "shadow",
                    "idempotency_key": idem_key,
                })
                processed_ids.add(idem_key)
                continue

            prompt = (
                f"Triage issue #{issue_number} in {repo}: \"{title}\" by @{author}. "
                f"Read the full issue with: gh issue view {issue_number} --repo {repo} "
                f"Read through the issue carefully and: "
                f"1) Identify the core problem or request. "
                f"2) Assess reproducibility — is there enough information to reproduce? "
                f"3) Assess impact — how many users does this affect, how severe is it? "
                f"4) Suggest possible approaches to address it. "
                f"Do NOT post a comment on the issue. Just present your analysis here."
            )

            branch_name = f"triage/{repo.split('/')[1]}-{issue_number}"
            if spawn_tangent(branch_name, prompt):
                log_event({
                    "mode": "issues",
                    "repo": repo,
                    "issue": issue_number,
                    "action": "triage_spawned",
                    "idempotency_key": idem_key,
                })
            else:
                log.warning("Issue triage deferred for #%s (%s)", issue_number, repo)
                continue  # don't mark processed — retry next tick

            processed_ids.add(idem_key)

        if new_cursor:
            cursors[cursor_key] = new_cursor


# ── Singleton lock ────────────────────────────────────────────────────────

def acquire_lock():
    fd = open(LOCK_FILE, "w")
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        fd.write(str(os.getpid()))
        fd.flush()
        return fd
    except BlockingIOError:
        fd.close()
        return None


# ── Main loop ─────────────────────────────────────────────────────────────

def run_daemon(foreground=False):
    # Fast-path idempotency check — exit silently if already running
    fd = open(LOCK_FILE, "w")
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        fd.close()
        sys.exit(0)
    fcntl.flock(fd, fcntl.LOCK_UN)
    fd.close()

    if not foreground:
        # Double-fork to detach fully from the parent shell
        if os.fork() > 0:
            sys.exit(0)
        os.setsid()
        if os.fork() > 0:
            sys.exit(0)
        # Redirect stdio to /dev/null and switch logs to file
        devnull = open("/dev/null", "r+")
        os.dup2(devnull.fileno(), sys.stdin.fileno())
        os.dup2(devnull.fileno(), sys.stdout.fileno())
        os.dup2(devnull.fileno(), sys.stderr.fileno())
        _log_to_file()
    else:
        _log_to_file()

    lock_fd = acquire_lock()
    if lock_fd is None:
        # Another instance won the race
        sys.exit(0)

    signal.signal(signal.SIGINT, _handle_signal)
    signal.signal(signal.SIGTERM, _handle_signal)

    log.info("pr-daemon started (PID=%d)", os.getpid())

    processed_ids = load_processed_ids()
    log.info("Loaded %d processed events from log", len(processed_ids))

    while not _shutdown:
      try:
        config = load_config()
        if config is None:
            log.error("No valid config — sleeping 60s")
            _sleep(60)
            continue

        global _spawns_this_tick, _injected_this_tick
        _spawns_this_tick = 0
        _injected_this_tick = set()  # pane_ids already injected into this tick
        cursors = load_cursors()
        poll_interval = config.get("poll_interval", 300)

        for repo in config.get("repos", []):
            if _shutdown:
                break
            try:
                poll_review_comments(repo, cursors, processed_ids, config)
            except Exception as e:
                log.error("Error polling review comments for %s: %s", repo, e)
            try:
                poll_issue_comments(repo, cursors, processed_ids, config)
            except Exception as e:
                log.error("Error polling issue comments for %s: %s", repo, e)
            try:
                poll_pr_reviews(repo, cursors, processed_ids, config)
            except Exception as e:
                log.error("Error polling PR reviews for %s: %s", repo, e)
            try:
                poll_pr_health(repo, cursors, processed_ids, config)
            except Exception as e:
                log.error("Error polling PR health for %s: %s", repo, e)

        if not _shutdown:
            try:
                poll_patch_critic(config, cursors, processed_ids)
            except Exception as e:
                log.error("Error in patch critic poll: %s", e)

        if not _shutdown:
            try:
                check_merge_cascade(config, cursors)
            except Exception as e:
                log.error("Error in merge cascade: %s", e)

        for repo in config.get("repos", []):
            if _shutdown:
                break
            try:
                check_auto_merge(repo, processed_ids, config)
            except Exception as e:
                log.error("Error in auto-merge check for %s: %s", repo, e)

        if not _shutdown:
            try:
                poll_issues(config, cursors, processed_ids)
            except Exception as e:
                log.error("Error polling issues: %s", e)

        save_cursors(cursors)

        _sleep(poll_interval)
      except Exception as e:
        log.exception("Unhandled error in daemon tick — continuing: %s", e)
        _sleep(60)

    log.info("pr-daemon stopped")
    lock_fd.close()


def _sleep(seconds):
    for _ in range(int(seconds)):
        if _shutdown:
            break
        time.sleep(1)


# ── CLI ───────────────────────────────────────────────────────────────────

def cmd_status():
    """Print daemon status and recent events."""
    lock_fd = open(LOCK_FILE, "a") if LOCK_FILE.exists() else None
    running = False
    if lock_fd:
        try:
            fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
            fcntl.flock(lock_fd, fcntl.LOCK_UN)
        except BlockingIOError:
            running = True
        lock_fd.close()

    print(f"Status: {'running' if running else 'stopped'}")

    if EVENT_LOG.exists():
        lines = EVENT_LOG.read_text().strip().split("\n")
        recent = lines[-10:] if len(lines) > 10 else lines
        print(f"\nRecent events ({len(lines)} total):")
        for line in recent:
            try:
                ev = json.loads(line)
                ts = ev.get("ts", "?")[:19]
                action = ev.get("action", "?")
                mode = ev.get("mode", "?")
                pr = ev.get("pr", "?")
                commenter = ev.get("commenter", "")
                print(f"  {ts}  mode={mode}  PR#{pr}  @{commenter}  -> {action}")
            except json.JSONDecodeError:
                pass

    if INBOX_FILE.exists():
        inbox = INBOX_FILE.read_text().strip()
        if inbox:
            count = len(inbox.split("\n"))
            print(f"\nInbox: {count} unrouted items (see {INBOX_FILE})")


def cmd_inbox():
    """Print and clear the inbox."""
    if not INBOX_FILE.exists():
        print("Inbox is empty")
        return
    content = INBOX_FILE.read_text().strip()
    if not content:
        print("Inbox is empty")
        return
    print(content)
    INBOX_FILE.write_text("")
    print(f"\n--- Inbox cleared ---")


def cmd_tail():
    """Tail the daemon's narrative log."""
    if not LOG_FILE.exists():
        LOG_FILE.touch()
    os.execvp("tail", ["tail", "-n", "50", "-f", str(LOG_FILE)])


def cmd_critic(repo, pr_number):
    """Spawn a Mode B critic for a specific PR, on demand."""
    pr = gh_api(f"/repos/{repo}/pulls/{pr_number}")
    if not pr:
        print(f"Could not fetch PR {repo}#{pr_number}", file=sys.stderr)
        sys.exit(1)
    if pr.get("state") != "open":
        print(f"PR {repo}#{pr_number} is {pr.get('state')}, not open", file=sys.stderr)
        sys.exit(1)

    config = load_config() or {}
    author = pr["user"]["login"]
    head_ref = pr["head"]["ref"]
    head_sha = pr["head"]["sha"]
    title = pr["title"]
    base = pr["base"]["ref"]
    is_self = author == config.get("pr_author", "JohnLangford")

    print(f"PR #{pr_number} ({repo}): \"{title}\" by @{author}")
    print(f"  head: {head_ref} ({head_sha[:8]})  base: {base}  self-authored: {is_self}")

    if is_self:
        prompt = (
            f"Review PR #{pr_number} in {repo}: \"{title}\". "
            f"Branch {head_ref} targeting {base}. "
            f"Run: gh pr diff {pr_number} --repo {repo} "
            f"to read the full diff. Also read the PR description with: "
            f"gh pr view {pr_number} --repo {repo} "
            f"Critique for correctness, design, test coverage, "
            f"performance, and security. For any substantive issues "
            f"you find, fix them directly — edit the code, commit, "
            f"and push. Skip style nits."
        )
    else:
        prompt = (
            f"Review PR #{pr_number} in {repo}: \"{title}\" by @{author}. "
            f"Branch {head_ref} targeting {base}. "
            f"Run: gh pr diff {pr_number} --repo {repo} "
            f"to read the full diff. Also read the PR description with: "
            f"gh pr view {pr_number} --repo {repo} "
            f"Critique the patch for correctness, design, test coverage, "
            f"performance, throughput, security, and backward "
            f"compatibility. Also flag any more elegant alternative "
            f"approach that accomplishes the same thing. "
            f"Then post your review as a PR comment with: "
            f"gh pr comment {pr_number} --repo {repo} --body \"<your review>\". "
            f"Start the comment with \"This is John's reviewbot.\" "
            f"Be concise and constructive. Focus on substantive issues, "
            f"not style nits."
        )

    acted = False
    if is_self:
        pane_id = find_pane_for_branch(head_ref)
        if pane_id and is_pane_idle(pane_id):
            acted = inject_into_pane(pane_id, f"[PR Daemon] {prompt}")
            if acted:
                print(f"Injected critic into pane {pane_id}")

    if not acted:
        branch_name = f"critic/{repo.split('/')[1]}-{pr_number}"
        acted = spawn_tangent(branch_name, prompt)
        if acted:
            print(f"Spawned tangent on branch {branch_name}")

    if not acted:
        print("Failed to spawn critic", file=sys.stderr)
        sys.exit(1)


def main():
    STATE_DIR.mkdir(parents=True, exist_ok=True)

    if len(sys.argv) > 1:
        cmd = sys.argv[1]
        if cmd == "status":
            cmd_status()
        elif cmd == "inbox":
            cmd_inbox()
        elif cmd == "tail":
            cmd_tail()
        elif cmd == "run":
            fg = "--foreground" in sys.argv[2:] or "-f" in sys.argv[2:]
            run_daemon(foreground=fg)
        elif cmd == "critic":
            if len(sys.argv) < 4:
                print("Usage: pr-daemon critic <repo> <pr-number>", file=sys.stderr)
                print("  e.g. pr-daemon critic microsoft/aifsdk 594", file=sys.stderr)
                sys.exit(1)
            cmd_critic(sys.argv[2], sys.argv[3])
        else:
            print(f"Usage: pr-daemon [run|status|inbox|tail|critic]", file=sys.stderr)
            sys.exit(1)
    else:
        run_daemon()


if __name__ == "__main__":
    main()
