#!/bin/bash
set -euo pipefail
# tangent-full -- fork completed Copilot CLI history into an isolated tangent.
# Clones history before the triggering command under a fresh session id, then
# hands it to `tangent` for a separate worktree, pane, and independent resume.
#
# Usage:
#   tangent-full <branch-name> ["<prompt>"]
#
# The optional prompt is auto-sent to the resumed session as the next turn.
#
# How the parent session is located (first hit wins):
#   1. $COPILOT_AGENT_SESSION_ID           (set by Copilot CLI for tool calls)
#   2. $COPILOT_EVENTS_LOG_DIRECTORY       (the live session's state dir)
#   3. the most-recently-updated session whose workspace.yaml cwd/git_root
#      matches the current repo (fallback)

STATE_ROOT="${COPILOT_STATE_ROOT:-$HOME/.copilot/session-state}"

die() { echo "tangent-full: $*" >&2; exit 1; }

BRANCH="${1:-}"
PROMPT="${2:-}"

case "$BRANCH" in
    -h|--help|help)
        cat <<'EOF'
tangent-full -- fork completed Copilot CLI history into an isolated tangent.

Usage:
  tangent-full <branch-name> ["<prompt>"]

Clones completed session history before this command under a fresh id and
resumes it in a new git worktree + tmux pane via the `tangent` engine. An
optional prompt is auto-sent to the resumed session.
EOF
        exit 0 ;;
esac

[[ -n "$BRANCH" ]] || die "usage: tangent-full <branch-name> [\"prompt\"]"
command -v tangent >/dev/null 2>&1 || die "the 'tangent' engine is not on PATH"
[[ -d "$STATE_ROOT" ]] || die "no session-state directory at $STATE_ROOT"

# ── Locate the parent session directory ────────────────────────────────
PARENT_DIR=""
LIVE_TOOL_CALL=false
if [[ -n "${COPILOT_AGENT_SESSION_ID:-}" && -d "$STATE_ROOT/$COPILOT_AGENT_SESSION_ID" ]]; then
    PARENT_DIR="$STATE_ROOT/$COPILOT_AGENT_SESSION_ID"
    LIVE_TOOL_CALL=true
elif [[ -n "${COPILOT_EVENTS_LOG_DIRECTORY:-}" && -d "$COPILOT_EVENTS_LOG_DIRECTORY" ]]; then
    PARENT_DIR="$COPILOT_EVENTS_LOG_DIRECTORY"
    LIVE_TOOL_CALL=true
else
    HERE=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
    PARENT_DIR=$(grep -lsE "^(cwd|git_root): ?${HERE}\$" "$STATE_ROOT"/*/workspace.yaml 2>/dev/null \
        | while read -r f; do d=$(dirname "$f"); printf '%s\t%s\n' "$(stat -c %Y "$d")" "$d"; done \
        | sort -rn | head -1 | cut -f2)
fi
[[ -n "$PARENT_DIR" && -d "$PARENT_DIR" ]] || \
    die "could not locate the current session to fork (COPILOT_AGENT_SESSION_ID unset and no workspace matched $PWD)"

OLD_ID="$(basename "$PARENT_DIR")"
NEW_ID="$(cat /proc/sys/kernel/random/uuid)"
NEW_DIR="$STATE_ROOT/$NEW_ID"

# ── Clone the session state under the new id ───────────────────────────
cp -r "$PARENT_DIR" "$NEW_DIR" || die "failed to clone session state"
# A copied lock would make the fork look busy; drop it.
rm -f "$NEW_DIR"/inuse.*.lock 2>/dev/null || true
# Repoint the session identity from the old id to the new id wherever it is
# embedded, so the fork is a fully independent session (not an alias).
[[ -f "$NEW_DIR/events.jsonl" ]] && sed -i "s/${OLD_ID}/${NEW_ID}/g" "$NEW_DIR/events.jsonl"
[[ -f "$NEW_DIR/workspace.yaml" ]] && sed -i "s/^id: .*/id: ${NEW_ID}/" "$NEW_DIR/workspace.yaml"

# ── Break the fork's self-reinvocation ─────────────────────────────────
# Remove live full-command triggers so resumed history cannot fork again
if [[ "$LIVE_TOOL_CALL" == "true" ]]; then
    if [[ ! -f "$NEW_DIR/events.jsonl" ]]; then
        rm -rf "$NEW_DIR"
        die "cloned live session is missing events.jsonl"
    fi

    if ! TRIGGER_LINE=$(awk '
        {
            is_system = ($0 ~ /^\{"type":"system\.message"/)
            is_user = ($0 ~ /^\{"type":"user\.message"/)
            is_turn_end = ($0 ~ /^\{"type":"assistant\.turn_end"/)

            if (is_user) {
                user_start = previous_was_system ? NR - 1 : NR
                latest_user_start = user_start
                is_full_slash = ($0 ~ /"content"[[:space:]]*:[[:space:]]*"\/tangent:full([[:space:]]|")/)
            }

            interaction_id = ""
            if (match($0, /"interactionId":"[^"]+"/)) {
                interaction_id = substr($0, RSTART + 17, RLENGTH - 18)
                current_interaction_id = interaction_id

                if (is_user && !(interaction_id in first_user_start)) {
                    first_user_start[interaction_id] = user_start
                }
                if (is_user && $0 ~ /"delivery":/) {
                    latest_delivered_user_start[interaction_id] = user_start
                }
            }

            if (is_user && $0 ~ /"delivery":/) {
                latest_delivered_is_full = is_full_slash
                if (is_full_slash) {
                    if (!full_command_chain_start) {
                        full_command_chain_start = user_start
                    }
                } else {
                    full_command_chain_start = 0
                    full_user_start = 0
                    full_interaction_id = ""
                    legacy_full_turn_ended = 0
                }
            }

            legacy_full = ($0 ~ /^\{"type":"skill\.invoked"/ &&
                $0 ~ /"name"[[:space:]]*:[[:space:]]*"full"/ &&
                $0 ~ /"pluginName"[[:space:]]*:[[:space:]]*"tangent"/)
            tool_full = ($0 ~ /^\{"type":"tool\.execution_start"/ &&
                $0 ~ /"toolName"[[:space:]]*:[[:space:]]*"skill"/ &&
                $0 ~ /"skill"[[:space:]]*:[[:space:]]*"full"/)

            if ((legacy_full || tool_full) && latest_user_start) {
                full_user_start = full_command_chain_start ? full_command_chain_start : latest_user_start
                full_interaction_id = current_interaction_id
                legacy_full_turn_ended = 0
            } else if (is_turn_end && full_user_start && !full_interaction_id) {
                legacy_full_turn_ended = 1
            } else if (is_user && legacy_full_turn_ended) {
                full_user_start = 0
                legacy_full_turn_ended = 0
            }

            if (is_turn_end || $0 ~ /^\{"type":"session\.shutdown"/) {
                active_turn = 0
            } else if ($0 ~ /^\{"type":"assistant\.(message|turn_start)"/ ||
                $0 ~ /^\{"type":"tool\.execution_start"/) {
                active_turn = 1
            }
            previous_was_system = is_system
        }
        END {
            if (!active_turn) {
                exit
            }

            if (latest_delivered_is_full && full_command_chain_start) {
                print full_command_chain_start
            } else if (full_user_start &&
                (!full_interaction_id || !current_interaction_id ||
                    full_interaction_id == current_interaction_id)) {
                print full_user_start
            } else if (latest_delivered_user_start[current_interaction_id]) {
                print latest_delivered_user_start[current_interaction_id]
            } else if (first_user_start[current_interaction_id]) {
                print first_user_start[current_interaction_id]
            } else if (latest_user_start) {
                print latest_user_start
            }
        }
    ' "$NEW_DIR/events.jsonl"); then
        rm -rf "$NEW_DIR"
        die "failed to inspect the cloned event log"
    fi

    if [[ -z "$TRIGGER_LINE" ]]; then
        rm -rf "$NEW_DIR"
        die "could not verify the triggering user turn; refusing to resume an untrimmed live session"
    fi

    if ! awk -v trigger_line="$TRIGGER_LINE" '
        NR >= trigger_line {
            exit
        }
        /^\{"type":"user\.message"/ &&
            (index($0, "\"source\":\"skill-full\"") ||
                index($0, "\"content\":\"<skill-context name=\\\"full\\\">")) {
            next
        }
        {
            print
        }
    ' "$NEW_DIR/events.jsonl" > "$NEW_DIR/events.jsonl.tmp" ||
        ! mv "$NEW_DIR/events.jsonl.tmp" "$NEW_DIR/events.jsonl"; then
        rm -rf "$NEW_DIR"
        die "failed to trim the triggering user turn from the cloned event log"
    fi
    echo "tangent-full: trimmed triggering command turn (from line $TRIGGER_LINE) to stop recursive forking"
fi

echo "tangent-full: forked session ${OLD_ID} -> ${NEW_ID}"

# ── Hand off to the engine ─────────────────────────────────────────────
# The engine creates the worktree + pane, repoints the forked workspace.yaml
# to that worktree, and launches `copilot --resume=<NEW_ID>`.
export TANGENT_RESUME_ID="$NEW_ID"
export TANGENT_RESUME_DIR="$NEW_DIR"
exec tangent "$BRANCH" "$PROMPT"
