#!/bin/bash
set -euo pipefail
# tangent -- spawn an isolated copilot session for a side task.
#
# Creates a git worktree on a new branch, opens a tmux pane in the
# right column, and launches copilot with the given prompt.
#
# Layout convention:
#   Column 0 (left):   pane 0, the "working" pane -- never touched
#   Column 1 (middle): monitoring/tangent panes -- vertically equalized
#   Column 2 (right):  overflow when column 1 is full (>= 4 panes)
#
# Usage:
#   tangent <branch-name> "<prompt>"
#   tangent <branch-name>               # opens copilot with no initial prompt
#
# The worktree is created at $HOME/worktrees/<branch-name>/<repo-subdir>
# where repo-subdir matches the current repo layout.

WORKTREE_ROOT="${WORKTREE_ROOT:-$HOME/worktrees}"
MIN_PANE_HEIGHT=8  # minimum usable height for Copilot (prompt + a few lines of output)
# MAX_COL_PANES is computed dynamically from window height

die() { echo "tangent: $*" >&2; exit 1; }

# ── Args ───────────────────────────────────────────────────────────────

BRANCH="${1:-}"
PROMPT="${2:-}"

case "$BRANCH" in
    -h|--help|help)
        cat <<'EOF'
tangent -- spawn an isolated copilot session for a side task.

Creates a git worktree on a new branch, opens a tmux pane in the right
column, and launches copilot with the given prompt.

Usage:
  tangent <branch-name> "<prompt>"     run a tangent with an initial prompt
  tangent <branch-name>                open a copilot session with no prompt
  tangent --help                       show this message

Branch-name conventions:
  foo                  auto-prefixed to <username>/foo
  jcl/foo, feat/foo    used verbatim (any name containing a slash)

Worktree path:
  $HOME/worktrees/<branch-name>/<repo-subdir>

Layout convention:
  Column 0 (left):   working pane, never touched
  Column 1 (middle): monitoring/tangent panes
  Column 2 (right):  overflow when column 1 is full

Resuming an existing tangent:
  Re-run tangent with the same branch name -- if the worktree exists,
  tangent attaches to its copilot session via `copilot --resume`.
EOF
        exit 0 ;;
esac

[[ -n "$BRANCH" ]] || die "usage: tangent <branch-name> [\"prompt\"]"

# Default to username/ prefix when branch has no slash
if [[ "$BRANCH" != */* ]]; then
    USERNAME="${SHORT_USERNAME:-${USER%%@*}}"
    BRANCH="${USERNAME}/${BRANCH}"
fi

# ── Detect repo ────────────────────────────────────────────────────────

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || die "not in a git repo"
REPO_NAME=$(basename "$REPO_ROOT")

# Worktree destination. New tangents branch from the current HEAD so they
# start from whatever you're working on right now (override the base by
# exporting TANGENT_BASE_REF, e.g. origin/main).
CURRENT_HEAD=$(git rev-parse HEAD)
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null || echo "detached")
WORKTREE_DIR="${WORKTREE_ROOT}/${BRANCH}"
# Check if a tangent pane already exists for this branch. We match on
# the pane's @label user option rather than pane_title, because Copilot
# CLI overwrites pane_title via OSC escape sequences seconds after launch.
EXISTING_PANE=$(tmux list-panes -a -F '#{pane_id} #{@label}' 2>/dev/null | awk -v b="$BRANCH" '$2 == b {print $1; exit}')
if [[ -n "$EXISTING_PANE" ]]; then
    echo "tangent: pane $EXISTING_PANE already running for branch $BRANCH — focusing it"
    tmux select-pane -t "$EXISTING_PANE"
    exit 0
fi

WORKTREE_PREEXISTED=false
if [[ -d "$WORKTREE_DIR" ]]; then
    WORKTREE_PREEXISTED=true
    echo "tangent: worktree already exists at $WORKTREE_DIR (will resume prior copilot session)"
else
    # Branch from the current HEAD by default; override with TANGENT_BASE_REF
    # (e.g. origin/main) to pin every tangent to a fixed base instead.
    BASE_REF="${TANGENT_BASE_REF:-$CURRENT_HEAD}"
    git worktree add "$WORKTREE_DIR" -b "$BRANCH" "$BASE_REF" 2>/dev/null ||
    git worktree add "$WORKTREE_DIR" "$BRANCH" 2>/dev/null ||
    die "failed to create worktree for branch '$BRANCH'"
    echo "tangent: created worktree at $WORKTREE_DIR (from $CURRENT_BRANCH)"
fi

# If the current dir is a subdirectory of the repo, mirror that
RELATIVE=$(realpath --relative-to="$REPO_ROOT" "$(pwd)" 2>/dev/null) || RELATIVE=""
if [[ -n "$RELATIVE" && "$RELATIVE" != "." && -d "$WORKTREE_DIR/$RELATIVE" ]]; then
    TARGET_DIR="$WORKTREE_DIR/$RELATIVE"
else
    TARGET_DIR="$WORKTREE_DIR"
fi

# ── Tmux layout ───────────────────────────────────────────────────────

# Verify we can reach the tmux server (either from inside a session via $TMUX,
# or from outside — e.g., systemd — via the default socket).
if [[ -z "${TMUX:-}" ]] && ! tmux list-sessions >/dev/null 2>&1; then
    die "not inside a tmux session and no tmux server reachable"
fi
CURRENT_WINDOW=$(tmux display-message -p '#{window_id}')

# Collect pane info for current window only
get_panes() {
    tmux list-panes -t "$CURRENT_WINDOW" -F '#{pane_id} #{pane_left} #{pane_top} #{pane_width} #{pane_height}'
}

# Group panes into columns by x-position.
# Returns: col_index pane_id pane_top pane_height
panes_by_column() {
    get_panes | sort -k2,2n -k3,3n | awk '
    {
        id=$1; x=$2; y=$3; w=$4; h=$5
        if (NR == 1 || x != prev_x) { col++ }
        prev_x = x
        print col, id, y, h
    }'
}

# Count columns
n_cols() {
    panes_by_column | awk '{print $1}' | sort -u | wc -l
}

# Count panes in a given column
col_pane_count() {
    panes_by_column | awk -v c="$1" '$1 == c' | wc -l
}

# Get pane IDs in a given column (top to bottom)
col_pane_ids() {
    panes_by_column | awk -v c="$1" '$1 == c {print $2}'
}

# Get the bottom-most pane in a column
col_bottom_pane() {
    panes_by_column | awk -v c="$1" '$1 == c {last=$2} END {print last}'
}

# Equalize vertical space for all panes in a column
equalize_column() {
    local col="$1"
    local pane_ids=($(col_pane_ids "$col"))
    local n=${#pane_ids[@]}
    [[ $n -le 1 ]] && return

    # Get total height available for this column (sum of all pane heights + separators)
    local total_h=0
    local heights=()
    while IFS=' ' read -r c pid ptop pheight; do
        if [[ "$c" == "$col" ]]; then
            total_h=$((total_h + pheight))
        fi
    done <<< "$(panes_by_column)"

    # Add separator lines back (n-1 separators of 1 line each)
    total_h=$((total_h + n - 1))
    local per_pane=$((total_h / n))

    # Resize all but the last pane (last one gets the remainder)
    for ((i=0; i < n-1; i++)); do
        tmux resize-pane -t "${pane_ids[$i]}" -y "$per_pane" 2>/dev/null || true
    done
}

# Equalize column *widths* so every column occupies an equal share of the
# window. Crucially this preserves the vertical pane stack inside each column:
# panes in a column share an x-position, so resizing one representative pane per
# column resizes the whole column without re-tiling. This is the stack-safe
# alternative to `select-layout even-horizontal`, which would flatten every
# stacked pane (e.g. the CLI column's watch panes) into its own column.
equalize_column_widths() {
    local win_w per i
    win_w=$(tmux display-message -t "$CURRENT_WINDOW" -p '#{window_width}')
    # One representative pane id per column (topmost of each distinct x), left→right.
    local reps=()
    mapfile -t reps < <(tmux list-panes -t "$CURRENT_WINDOW" -F '#{pane_left} #{pane_top} #{pane_id}' \
        | sort -k1,1n -k2,2n | awk '!seen[$1]++ {print $3}')
    local ncols=${#reps[@]}
    [[ $ncols -le 1 ]] && return
    per=$(( win_w / ncols ))
    # Resize every column but the last to `per`; the last absorbs the remainder.
    for ((i = 0; i < ncols - 1; i++)); do
        tmux resize-pane -t "${reps[$i]}" -x "$per" 2>/dev/null || true
    done
}

# Decide where to put the new pane
NCOLS=$(n_cols)
WIN_HEIGHT=$(tmux display-message -p '#{window_height}')
# Each pane needs MIN_PANE_HEIGHT + 1 line for the separator
MAX_COL_PANES=$(( WIN_HEIGHT / (MIN_PANE_HEIGHT + 1) ))
[[ $MAX_COL_PANES -lt 2 ]] && MAX_COL_PANES=2

# Pick the column with fewest panes that hasn't hit the limit.
# Height available in a column (sum of pane heights + separators)
col_total_height() {
    local col="$1" total=0 n=0
    while IFS=' ' read -r c pid ptop pheight; do
        if [[ "$c" == "$col" ]]; then
            total=$((total + pheight))
            n=$((n + 1))
        fi
    done <<< "$(panes_by_column)"
    # Add back separator lines between panes
    echo $((total + n - 1))
}

# Column 1 (leftmost) is the working pane — never split vertically there.
pick_target_col() {
    local best_col="" best_count=999
    for col in $(seq 2 "$NCOLS"); do
        local count=$(col_pane_count "$col")
        local height=$(col_total_height "$col")
        # After adding a pane, each pane gets height/(count+1) lines
        # (minus separators). Skip if that's below MIN_PANE_HEIGHT.
        local per_pane=$(( (height - count) / (count + 1) ))
        if [[ $per_pane -lt $MIN_PANE_HEIGHT ]]; then
            continue
        fi
        if [[ $count -lt $MAX_COL_PANES && $count -lt $best_count ]]; then
            best_col=$col
            best_count=$count
        fi
    done
    echo "$best_col"
}

if [[ $((NCOLS - 1)) -lt 2 ]]; then
    # Fewer than two agent columns — open a new one. The leftmost column is the
    # user's working/CLI column and is never split or restructured: its vertical
    # pane stack (e.g. a shell plus watch panes) must stay intact. `-fh` carves a
    # full-height column down the right edge of the window, spanning the whole
    # height, so it never disturbs any column's stacking the way
    # `select-layout even-horizontal` did. Widths are evened out below.
    NEW_PANE=$(tmux split-window -fh -t "$CURRENT_WINDOW" -c "$TARGET_DIR" -d -P -F '#{pane_id}')
    NEW_COL=$((NCOLS + 1))
else
    TARGET_COL=$(pick_target_col)
    if [[ -n "$TARGET_COL" ]]; then
        # Add to the least-loaded column
        SPLIT_TARGET=$(col_bottom_pane "$TARGET_COL")
        NEW_PANE=$(tmux split-window -v -t "$SPLIT_TARGET" -c "$TARGET_DIR" -d -P -F '#{pane_id}')
        NEW_COL=$TARGET_COL
    else
        # Primary window full — overflow to secondary window.
        source "$(dirname "$(readlink -f "$0")")/pane-layout.sh"
        SECONDARY=$(ensure_secondary_window)
        echo "tangent: primary full, using overflow window"

        SEC_TARGET_COL=$(pick_target_col "$SECONDARY")
        if [[ -n "$SEC_TARGET_COL" ]]; then
            SPLIT_TARGET=$(col_bottom_pane "$SEC_TARGET_COL" "$SECONDARY")
            NEW_PANE=$(tmux split-window -v -t "$SPLIT_TARGET" -c "$TARGET_DIR" -d -P -F '#{pane_id}')
            NEW_COL=$SEC_TARGET_COL
        else
            SEC_NCOLS=$(n_cols "$SECONDARY")
            if [[ $SEC_NCOLS -lt 2 ]]; then
                SPLIT_TARGET=$(col_bottom_pane 1 "$SECONDARY")
                NEW_PANE=$(tmux split-window -h -t "$SPLIT_TARGET" -c "$TARGET_DIR" -d -P -F '#{pane_id}')
                NEW_COL=2
            else
                # Overflow of overflow — add to tallest column
                TALLEST_COL="" TALLEST_H=0
                for col in $(seq 2 "$SEC_NCOLS"); do
                    H=$(col_total_height "$col" "$SECONDARY")
                    if [[ $H -gt $TALLEST_H ]]; then
                        TALLEST_H=$H
                        TALLEST_COL=$col
                    fi
                done
                SPLIT_TARGET=$(col_bottom_pane "${TALLEST_COL:-2}" "$SECONDARY")
                NEW_PANE=$(tmux split-window -v -t "$SPLIT_TARGET" -c "$TARGET_DIR" -d -P -F '#{pane_id}')
                NEW_COL=${TALLEST_COL:-2}
            fi
        fi
        # Equalize in secondary
        [[ -n "${NEW_COL:-}" ]] && equalize_column "$NEW_COL" "$SECONDARY"
    fi
fi

# Equalize the affected column's pane heights, then even out all column widths.
# Both operations preserve the vertical stacks within each column (equal widths
# are applied by resizing one representative pane per column, not by re-tiling),
# so the CLI column keeps its stacked watch panes. Skipped when we spilled into
# the overflow window, which lays itself out above.
if [[ -z "${SECONDARY:-}" ]]; then
    [[ -n "${NEW_COL:-}" ]] && equalize_column "$NEW_COL"
    equalize_column_widths
fi

# Label the pane. @label is the authoritative, sticky label used by
# pane-border-format and by tangent's own existence check above — it
# survives OSC title updates from Copilot CLI. The pane_title is also
# set (cosmetic; tangent-close matches on cwd anyway).
tmux set-option -p -t "$NEW_PANE" @label "$BRANCH"
tmux select-pane -t "$NEW_PANE" -T "🌿 $BRANCH"

# ── Launch copilot ─────────────────────────────────────────────────────

# Permission posture for the spawned session. Defaults to --allow-all-tools
# (closest to Claude Code's --dangerously-skip-permissions) so the tangent
# runs unattended; override via TANGENT_COPILOT_PERMS (e.g. "--yolo" for full
# autonomy, or "" to be prompted for each action).
COPILOT_PERMS="${TANGENT_COPILOT_PERMS:---allow-all-tools}"
# Name each new session after its branch so it can be resumed by name later.
COPILOT_FLAGS="$COPILOT_PERMS --name \"$BRANCH\""
# Resume prior session when the worktree pre-existed and no new prompt is given.
# This rehydrates a previously-suspended Copilot session (killed via `tmux kill-pane`).
if [[ "$WORKTREE_PREEXISTED" == "true" && -z "$PROMPT" ]]; then
    COPILOT_FLAGS="$COPILOT_PERMS --resume=\"$BRANCH\""
fi

# Full-fidelity fork (invoked via `tangent-full`): a pre-cloned session has
# been staged for resume. Repoint its metadata at this worktree and resume it
# instead of starting fresh. A prompt, if given, is still auto-sent below.
if [[ -n "${TANGENT_RESUME_ID:-}" ]]; then
    if [[ -n "${TANGENT_RESUME_DIR:-}" && -f "$TANGENT_RESUME_DIR/workspace.yaml" ]]; then
        WS="$TANGENT_RESUME_DIR/workspace.yaml"
        sed -i \
            -e "s#^cwd: .*#cwd: $TARGET_DIR#" \
            -e "s#^git_root: .*#git_root: $WORKTREE_DIR#" \
            -e "s#^branch: .*#branch: $BRANCH#" \
            -e "s#^name: .*#name: $BRANCH#" \
            "$WS"
        grep -q '^name: ' "$WS" || printf 'name: %s\n' "$BRANCH" >> "$WS"
    fi
    COPILOT_FLAGS="$COPILOT_PERMS --resume=\"$TANGENT_RESUME_ID\""
fi

# Registry: record this tangent as live so reboot-recover can rehydrate
# it. Removal happens via the POST_EXIT chain when copilot exits cleanly
# (ctrl-c twice, or ctrl-d). Hard pane-kills leave a stale entry; reboot-
# recover GCs entries whose worktree no longer exists.
REGISTRY_FILE="$HOME/.local/state/tangent-active.txt"
mkdir -p "$(dirname "$REGISTRY_FILE")"
grep -qxF "$BRANCH" "$REGISTRY_FILE" 2>/dev/null || echo "$BRANCH" >> "$REGISTRY_FILE"

# Post-exit hook: when copilot in the new pane exits, remove the branch
# from the registry and inject a one-line completion notice into the
# originating pane (the same convention cjob_bench's --on-complete uses).
# When the parent pane is itself a Copilot session, the line lands as
# user input in that conversation; in a plain shell it just appears at
# the prompt.
PARENT_PANE="${TMUX_PANE:-}"
POST_EXIT="; sed -i \"\\|^$BRANCH\$|d\" '$REGISTRY_FILE' 2>/dev/null || true"
if [[ -n "$PARENT_PANE" ]]; then
    POST_EXIT="$POST_EXIT; tmux send-keys -t '$PARENT_PANE' 'tangent $BRANCH done.' Enter"
fi

if [[ -n "$PROMPT" ]]; then
    # Write prompt to a temp file to avoid quoting issues with send-keys
    PROMPT_FILE=$(mktemp /tmp/tangent-prompt-XXXXXX)
    echo "$PROMPT" > "$PROMPT_FILE"
    tmux send-keys -t "$NEW_PANE" "cd '$TARGET_DIR' && copilot $COPILOT_FLAGS -i \"\$(cat $PROMPT_FILE)\" ; rm -f $PROMPT_FILE${POST_EXIT}" Enter
else
    tmux send-keys -t "$NEW_PANE" "cd '$TARGET_DIR' && copilot $COPILOT_FLAGS${POST_EXIT}" Enter
fi

echo "tangent: launched in pane $NEW_PANE on branch $BRANCH"
echo "tangent: worktree at $TARGET_DIR"
